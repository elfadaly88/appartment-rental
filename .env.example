# =============================================================================
# Rentals Platform – Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before running Docker Compose:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=rentals_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=rentalsdb

# -----------------------------------------------------------------------------
# ASP.NET Core
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production

# -----------------------------------------------------------------------------
# JWT Authentication
# Generate a secure key: openssl rand -base64 64
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=YOUR_VERY_LONG_RANDOM_JWT_SECRET_KEY_MIN_32_CHARS
JWT_ISSUER=RentalsPlatformApi
JWT_AUDIENCE=RentalsPlatformClients
JWT_DURATION_MINUTES=1440

# -----------------------------------------------------------------------------
# Google OAuth  (https://console.cloud.google.com/)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# -----------------------------------------------------------------------------
# Facebook OAuth  (https://developers.facebook.com/)
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET

# -----------------------------------------------------------------------------
# VAPID keys for Web Push Notifications
# Generate with: npx web-push generate-vapid-keys
# -----------------------------------------------------------------------------
VAPID_SUBJECT=mailto:admin@yourdomain.com
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

# -----------------------------------------------------------------------------
# Paymob Payment Gateway  (https://accept.paymob.com/)
# -----------------------------------------------------------------------------
PAYMOB_API_KEY=YOUR_PAYMOB_API_KEY
PAYMOB_SECRET_KEY=YOUR_PAYMOB_SECRET_KEY
PAYMOB_PUBLIC_KEY=YOUR_PAYMOB_PUBLIC_KEY
PAYMOB_HMAC_SECRET=YOUR_PAYMOB_HMAC_SECRET
PAYMOB_INTEGRATION_ID=4028437
PAYMOB_IFRAME_ID=0
PAYMOB_BASE_URL=https://accept.paymob.com/api
# Update to your VPS IP or domain once deployed:
PAYMOB_CHECKOUT_RETURN_URL=http://YOUR_DOMAIN_OR_IP/checkout/callback

# -----------------------------------------------------------------------------
# Cloudinary (https://cloudinary.com/console)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# -----------------------------------------------------------------------------
# Mapbox (https://account.mapbox.com/)
# -----------------------------------------------------------------------------
MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_ACCESS_TOKEN

# -----------------------------------------------------------------------------
# Public URLs  (set to your VPS IP or domain)
# With Nginx on port 80:
#   PUBLIC_API_URL=http://api.yourdomain.com/api
#   PUBLIC_HUB_URL=http://api.yourdomain.com/hubs/notifications
# Without domain (direct IP):
#   PUBLIC_API_URL=http://YOUR_VPS_IP/api
#   PUBLIC_HUB_URL=http://YOUR_VPS_IP/hubs/notifications
# -----------------------------------------------------------------------------
PUBLIC_API_URL=http://YOUR_VPS_IP/api
PUBLIC_HUB_URL=http://YOUR_VPS_IP/hubs/notifications
