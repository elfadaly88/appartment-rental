{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_CONNECTION_STRING_HERE"
  },
  "JwtSettings": {
    "Key": "YOUR_JWT_SECRET_KEY_HERE",
    "Issuer": "RentalsPlatformApi",
    "Audience": "RentalsPlatformClients",
    "DurationInMinutes": 1440
  },
  "ExternalAuth": {
    "Google": {
      "ClientId": "YOUR_GOOGLE_CLIENT_ID",
      "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
    },
    "Facebook": {
      "AppId": "YOUR_FACEBOOK_APP_ID",
      "AppSecret": "YOUR_FACEBOOK_APP_SECRET"
    }
  },
  "VapidDetails": {
    "Subject": "mailto:admin@rentalsplatform.com",
    "PublicKey": "YOUR_VAPID_PUBLIC_KEY",
    "PrivateKey": "YOUR_VAPID_PRIVATE_KEY"
  },
  "Paymob": {
    "ApiKey": "YOUR_PAYMOB_API_KEY",
    "SecretKey": "YOUR_PAYMOB_SECRET_KEY",
    "PublicKey": "YOUR_PAYMOB_PUBLIC_KEY",
    "HmacSecret": "YOUR_PAYMOB_HMAC_SECRET",
    "IntegrationId": 4028437,
    "IframeId": 0,
    "CheckoutReturnUrl": "http://localhost:4200/checkout/callback",
    "BaseUrl": "https://accept.paymob.com/api"
  },
  "CloudinarySettings": {
    "CloudName": "YOUR_CLOUDINARY_NAME",
    "ApiKey": "YOUR_CLOUDINARY_API_KEY",
    "ApiSecret": "YOUR_CLOUDINARY_API_SECRET"
  },
  "AllowedHosts": "*"
}
