          "startDate",
          "endDate",
          "reason"
        ],
        "type": "object",
        "properties": {
          "propertyId": {
            "type": "string",
            "format": "uuid"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          },
          "reason": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "BlockDto": {
        "required": [
          "propertyId",
          "startDate",
          "endDate",
          "reason"
        ],
        "type": "object",
        "properties": {
          "propertyId": {
            "type": "string",
            "format": "uuid"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          },
          "reason": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreatePropertyPriceRuleDto": {
        "type": "object",
        "properties": {
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          },
          "customPricePerNight": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "HostBankDetailsDto": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "bankAccountNumber": {
            "type": "string"
          },
          "bankIban": {
            "type": "string"
          },
          "nationalId": {
            "type": "string"
          },
          "addressLine": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
